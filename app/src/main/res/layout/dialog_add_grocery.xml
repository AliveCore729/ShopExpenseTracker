<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F3E5F5">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add_shopping" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Grocery Item"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What needs to be restocked?"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_regular"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F8FAFC"
            android:layout_marginTop="24dp">

            <AutoCompleteTextView
                android:id="@+id/etGroceryItem"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@null"
                android:hint="e.g. Milk 2 Packets"
                android:inputType="textCapSentences"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:textColor="#0F172A"
                android:textColorHint="#94A3B8"
                android:fontFamily="@font/poppins_regular"
                android:completionThreshold="1"/>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="#64748B"
                android:textStyle="bold"
                android:backgroundTint="#F1F5F9"
                app:cornerRadius="16dp"
                app:elevation="0dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdd"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Add Item"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#8200FF"
                app:cornerRadius="16dp"
                app:elevation="4dp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>